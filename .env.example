PROJECT_NAME=vision-mlops-classifier
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
APP_METRICS_PATH=/metrics
INFERENCE_BACKEND=torch
MODEL_ARCHITECTURE=resnet18
MODEL_CHECKPOINT=models/checkpoints/resnet18_best.pt
MODEL_ONNX_PATH=models/exported/resnet18.onnx
MODEL_VERSION=local-dev
MODEL_NUM_CLASSES=2
MODEL_CLASS_NAMES=class_a,class_b
MODEL_IMAGE_SIZE=224
PREDICTION_TOP_K=3
MLFLOW_TRACKING_URI=http://localhost:5000
PROMETHEUS_ENABLED=true